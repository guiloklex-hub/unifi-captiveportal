DATABASE_URL="file:./prisma/dev.db"

# UniFi Controller (self-hosted classic v10.1.89)
UNIFI_URL="https://192.168.1.1:8443"
UNIFI_USERNAME="portal-api"
UNIFI_PASSWORD="changeme"
UNIFI_SITE="default"
UNIFI_INSECURE_TLS="true"

# Guest authorization defaults (override per request if needed)
GUEST_DURATION_MIN="480"
GUEST_DOWN_KBPS="5120"
GUEST_UP_KBPS="2048"

# Where to send the user after successful authorization
PORTAL_SUCCESS_URL="https://empresa.com.br"

# Admin panel
ADMIN_PASSWORD="trocar-essa-senha"
ADMIN_SECRET="gere-com-openssl-rand-hex-32"

# Defina como "true" apenas se o app rodar com HTTPS
COOKIE_SECURE="false"
# AdGuard Home Integration
ADGUARD_URL="http://192.168.1.50"
ADGUARD_USER="admin"
ADGUARD_PASSWORD="sua-senha-aqui"

# Token de acesso — locks de configuração
# Quando definidas, estas variáveis "travam" os respectivos campos no painel
# admin (formulário de criação de token e checkbox em Customização).
# Os tokens criados passarão a usar SEMPRE o valor da variável, e o admin
# não poderá editar o campo correspondente. Se a variável estiver vazia ou
# ausente, o campo permanece editável no painel.
#
# TOKEN_LOCK_REQUIRE="true"          # força requireToken e oculta o checkbox em Customização
# TOKEN_LOCK_DURATION_MIN="240"      # trava duração da sessão em 240 minutos
# TOKEN_LOCK_MAX_USES="1"            # trava máx. de usos em 1 (token de uso único)
# TOKEN_LOCK_DOWN_KBPS="5120"        # trava limite download (use "0" para travar como "sem limite")
# TOKEN_LOCK_UP_KBPS="2048"          # trava limite upload (use "0" para travar como "sem limite")
# TOKEN_LOCK_BYTES_QUOTA_MB="1024"   # trava quota de dados (use "0" para travar como "sem limite")
# TOKEN_LOCK_EXPIRES_IN_MIN="1440"   # trava validade em janela relativa (minutos a partir da criação)
