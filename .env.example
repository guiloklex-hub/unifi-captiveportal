DATABASE_URL="file:./prisma/dev.db"

# UniFi Controller (self-hosted classic v10.1.89)
UNIFI_URL="https://192.168.1.1:8443"
UNIFI_USERNAME="portal-api"
UNIFI_PASSWORD="changeme"
UNIFI_SITE="default"
UNIFI_INSECURE_TLS="true"

# Guest authorization defaults (override per request if needed)
GUEST_DURATION_MIN="480"
GUEST_DOWN_KBPS="5120"
GUEST_UP_KBPS="2048"

# Where to send the user after successful authorization
PORTAL_SUCCESS_URL="https://empresa.com.br"

# Admin panel
ADMIN_PASSWORD="trocar-essa-senha"
ADMIN_SECRET="gere-com-openssl-rand-hex-32"

# Defina como "true" apenas se o app rodar com HTTPS
COOKIE_SECURE="false"
