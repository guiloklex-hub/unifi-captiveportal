generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model GuestRegistration {
  id           Int       @id @default(autoincrement())
  fullName     String
  email        String
  phone        String
  cpf          String
  macAddress   String
  authDate     String    @default("1970-01-01")
  apMac        String?
  ssid         String?
  site         String?
  userAgent    String?
  ipAddress    String?
  fingerprint  String?
  authorizedAt DateTime  @default(now())
  durationMin  Int
  downKbps     Int?
  upKbps       Int?
  bytesQuotaMB Int?
  bytesTx      BigInt?
  bytesRx      BigInt?
  lastSeenAt   DateTime?
  reconciledAt DateTime?

  tokenId String?
  token   AccessToken? @relation(fields: [tokenId], references: [id], onDelete: SetNull)

  @@unique([macAddress, authDate])
  @@index([cpf])
  @@index([macAddress])
  @@index([authorizedAt])
  @@index([tokenId])
  @@index([fingerprint])
}

model AccessToken {
  id           String    @id @default(cuid())
  code         String    @unique
  description  String?
  durationMin  Int
  downKbps     Int?
  upKbps       Int?
  bytesQuotaMB Int?
  maxUses      Int
  usedCount    Int       @default(0)
  expiresAt    DateTime
  revokedAt    DateTime?
  site         String    @default("default")
  createdAt    DateTime  @default(now())
  firstUsedAt  DateTime?

  registrations GuestRegistration[]

  @@index([code])
  @@index([expiresAt])
  @@index([site])
}

model SystemSettings {
  id            String   @id @default("config")
  brandName     String   @default("UniFi Portal")
  logoUrl       String?
  backgroundUrl String?
  primaryColor  String   @default("#171717")
  termsOfUse    String   @default("Ao conectar, você aceita os termos de uso e a política de privacidade.")
  requireToken  Boolean  @default(false)
  updatedAt     DateTime @updatedAt
}
